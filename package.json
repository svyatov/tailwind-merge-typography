{
  "name": "tailwind-merge-typography",
  "version": "1.0.0",
  "description": "A tailwind-merge plugin that teaches twMerge to resolve @tailwindcss/typography prose-* conflicts.",
  "keywords": [
    "tailwind-merge",
    "tailwindcss",
    "tailwind",
    "typography",
    "prose",
    "twmerge",
    "cn",
    "clsx",
    "plugin"
  ],
  "homepage": "https://github.com/svyatov/tailwind-merge-typography#readme",
  "bugs": {
    "url": "https://github.com/svyatov/tailwind-merge-typography/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svyatov/tailwind-merge-typography.git"
  },
  "license": "MIT",
  "author": "Leonid Svyatov <leonid@svyatov.com>",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target node --format esm --packages external && tsc --emitDeclarationOnly",
    "test": "bun test",
    "check": "biome check",
    "typecheck": "tsc --noEmit",
    "lint:pkg": "publint && attw --pack . --profile esm-only",
    "prepublishOnly": "bun run build && bun test"
  },
  "peerDependencies": {
    "tailwind-merge": ">=2.0.0 <4"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "publint": "^0.3.21",
    "tailwind-merge": "^3.6.0",
    "typescript": "^7.0.2"
  }
}
